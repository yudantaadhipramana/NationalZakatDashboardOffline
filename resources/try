                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${formatIDR(row.actual)}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${formatIDR(row.dist)}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${formatIDR(row.ops)}</td>

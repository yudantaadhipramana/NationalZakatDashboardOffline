        // 4. POPULATE TABLES
        function populateTables() {
            // Funnel Table
            const funnelBody = document.getElementById('funnel-table-body');
            dbData.funnel.forEach((row, idx) => {
                const conv = idx === 0 ? '100%' : ((row.users / dbData.funnel[0].users) * 100).toFixed(1) + '%';
                funnelBody.innerHTML += `
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${row.stage}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${row.users.toLocaleString()}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${conv}</td>
                    </tr>
                `;
            });

            // Programs Table
            const progBody = document.getElementById('programs-table-body');
            dbData.programs.forEach(row => {
                progBody.innerHTML += `
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${row.name}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${formatIDR(row.budget)}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${formatIDR(row.distributed)}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500">${row.beneficiaries.toLocaleString()}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-emerald-600 font-semibold">${row.sroi}x</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 font-bold">${row.score}</td>
                    </tr>
                `;
            });

            // Regional Table

        // 2. TAB SWITCHING LOGIC
        const tabTitles = {
            'exec-summary': '1. Executive Summary',
            'fundraising': '2. Fundraising Intelligence',
            'program-impact': '3. Program Impact Intelligence',
            'branch-perf': '4. Branch Performance Intelligence',
            'donor-360': '5. Donor 360 Analytics',
            'compliance': '6. Compliance & Audit Dashboard',
            'social-impact': '7. Social Impact Map',
            'predictive-ai': '8. Predictive AI Center'
        };

        function switchTab(tabId) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            // Show selected tab
            document.getElementById(tabId).classList.remove('hidden');

            // Update header title
            document.getElementById('current-tab-title').innerText = tabTitles[tabId];

            // Update active state on sidebar buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                if (btn.getAttribute('data-tab') === tabId) {
                    btn.classList.add('bg-emerald-700', 'text-white');
                    btn.classList.remove('text-emerald-100', 'hover:bg-emerald-800');
                } else {
                    btn.classList.remove('bg-emerald-700', 'text-white');
                    btn.classList.add('text-emerald-100', 'hover:bg-emerald-800');
                }
            });

            // Initialize charts for the active tab
            renderChartsForTab(tabId);
        }

        // 3. CHART INITIALIZATION & RENDERING
        const activeCharts = {};

        function destroyChart(chartId) {
            if (activeCharts[chartId]) {
                activeCharts[chartId].destroy();
                delete activeCharts[chartId];
            }
        }


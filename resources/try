                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-blue-600 font-semibold">${formatIDR(row.forecast)}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-400">${formatIDR(row.upper)}</td>
                    </tr>
                `;
            });
        }

